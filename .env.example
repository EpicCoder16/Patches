# Patches — environment config
# Copy this file to .env and fill in your values.

# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-your-key-here

# Model to use (optional — defaults to gemini-2.0-flash)
# Options:
#   gemini-2.0-flash        — default, fast, 15 req/min free
#   gemini-2.0-flash-lite   — faster/lighter
#   gemini-1.5-flash        — very capable
#   gemini-1.5-flash-8b     — smallest
PATCHES_MODEL=gemini-2.0-flash
