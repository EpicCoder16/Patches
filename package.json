{
  "name": "patches",
  "version": "1.0.0",
  "description": "AI-powered CSS patch injector for any website",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "prebuild": "node scripts/generate-icons.js",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac dmg zip",
    "build:win": "electron-builder --win nsis",
    "build:linux": "electron-builder --linux AppImage"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "png2icons": "^2.0.1",
    "sharp": "^0.33.5"
  },
  "dependencies": {},
  "build": {
    "appId": "app.patches.desktop",
    "productName": "Patches",
    "copyright": "Patches",
    "publish": null,
    "files": [
      "main.js",
      "preload.js",
      "settingsPreload.js",
      "renderer/**/*",
      "storage/**/*",
      "package.json",
      "!**/.git/**",
      "!**/.env",
      "!**/.env.*",
      "!**/.cache/**",
      "!node_modules/.cache/**",
      "!dist/**",
      "!build/**/*.psd",
      "!scripts/**",
      "!**/*.map",
      "!.github/**"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
